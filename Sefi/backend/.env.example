# ════════════════════════════════════════════════════════════════════════════
# liquifi (LiquidShield Guardian) — Sui plane. Copy real values into .env.
#
# MAINNET SWITCH-OVER (tonight's deploy): after Person 1 redeploys on mainnet, flip:
#   SUI_GRAPHQL_URL=https://graphql.mainnet.sui.io/graphql
#   SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
#   SUI_NETWORK=mainnet
#   DEEPBOOK_POOL_NAME=SUI_USDC                 (real mainnet pool; testnet = SUI_DBUSDC)
#   LIQUIDSHIELD_PACKAGE_ID / SHIELD_REGISTRY_ID / DAO_OVERRIDE_CAP_ID  -> new mainnet ids
#   RISK_POLICY_ID / VAULT_ID / SNAPSHOT_ID / POSITION_ID / GUARDIAN_CAP_ID -> from mainnet onboard
#   OBLIGATION_ID -> a REAL Scallop mainnet obligation (open->deposit->borrow)
#   SCALLOP_PACKAGE_ID / SCALLOP_VERSION_ID / SCALLOP_MARKET_ID / *_REGISTRY / *_XORACLE -> mainnet
#   COIN_TYPE -> mainnet USDC/SUI coin type as appropriate
# Everything reads from env, so mainnet = an env swap (no code change).
# SAFETY on mainnet: the agent moves REAL funds — keep the vault reserve small and set
# conservative max_per_action / max_daily; leave LIQUIDSHIELD_AUTO_EXECUTE=false until the
# demo, then enable just before the rescue scene.
# ════════════════════════════════════════════════════════════════════════════

# ── LiquidShield deployment (from ../../.env.deployed / ABI_FOR_PERSON2.md) ──
LIQUIDSHIELD_PACKAGE_ID=0x1a4bc48f7c7cff2bcada2189e3b9c9686c866579629d06af99278370e41f0ecf
SHIELD_REGISTRY_ID=0x0c002ee24b4beb2ce954c9113f12fec6b3549ac8e12739a501a863473a849b8b
DAO_OVERRIDE_CAP_ID=0x2b5a6347816149967714ea205381bf1a56da5d2dd33516c5375b6dafad789be0

# ── Per-position objects (from onboard_user.ts output) ──
RISK_POLICY_ID=0xee1abcfdb3300e2166d8ed2cc9041abad1dcd6bc3423f39e008cde2ead3cb557
VAULT_ID=0xcc9a44575022331c4ad22da618847b6c8f41ecda400f2e9042ea7b0ed544ba4f
SNAPSHOT_ID=0x12ad8fa2bc4c51e7030c6227827294c11f868988872f84cc68cf896ba3e759e0
POSITION_ID=0x820b4a4921d2866b49b91df8f7ab281d62a623101b7b6c779abb64064974ebbb
GUARDIAN_CAP_ID=0xdf1a52a687e91c195890e94ca908223d65a21f41db836356693dc2a8bd6c4a59
# OBLIGATION_ID — Scallop is MAINNET-ONLY (no testnet deployment). On testnet use the
# deployer address as a placeholder: LiquidShield only does an equality check
# (position.obligation_id == obligation_id), so begin_rescue -> complete_rescue runs
# end-to-end on testnet and emits a real ShieldActivatedEvent. On MAINNET set this to a
# real Scallop Obligation object id (open -> deposit -> borrow) for a real health factor.
OBLIGATION_ID=0x3d16b634d2c74c02b0d328caee23fc90e68616f768d461fee33d5a6493cf5ae3
PROTOCOL=scallop
COLLATERAL_ASSET=SUI
DEBT_ASSET=USDC
COIN_TYPE=0x2::sui::SUI

# ── Agent identity (holds GuardianCap; signs snapshots + rescues) ──
# Dedicated agent wallet; GuardianCap was minted to AGENT_ADDRESS. Fund it with testnet
# gas: https://faucet.sui.io/?address=0xdd731e5d93776dd1f01a7c1cc758d8b8bffc281326df6d11bc647c9e5cf63aac
AGENT_ADDRESS=0xdd731e5d93776dd1f01a7c1cc758d8b8bffc281326df6d11bc647c9e5cf63aac
AGENT_PRIVATE_KEY=0Nra2xIMaCFQ3DwsYSVkMs7ztgwRX7nx6YukR8tkPng=
USER_PRIVATE_KEY=

# ── Sui network ──
SUI_GRAPHQL_URL=https://graphql.testnet.sui.io/graphql
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_NETWORK=testnet

