{
  "protocol": "liquifi",
  "chain": "sui",
  "network": "testnet",
  "description": "LiquidShield Guardian (liquifi) event sources indexed via Sui GraphQL. Each source is queried by `module` filter (package or package::module). Scallop/NAVI/DeepBook are read for monitoring + risk signals.",
  "sources": [
    {
      "key": "liquidshield",
      "role": "core",
      "packageEnv": "LIQUIDSHIELD_PACKAGE_ID",
      "package": "0x1a4bc48f7c7cff2bcada2189e3b9c9686c866579629d06af99278370e41f0ecf",
      "modules": [
        "shield_executor",
        "shield_oracle",
        "risk_policy",
        "shield_registry",
        "shield_vault",
        "guardian_cap"
      ],
      "events": [
        "shield_executor::ShieldActivatedEvent",
        "shield_executor::ShieldBlockedEvent",
        "shield_oracle::RiskScoreUpdatedEvent",
        "shield_oracle::RiskSnapshotCreatedEvent",
        "risk_policy::PolicyCreatedEvent",
        "risk_policy::PolicyChangedEvent",
        "risk_policy::PolicyPausedEvent",
        "risk_policy::ProtectionRevokedEvent",
        "risk_policy::OverrideExecutedEvent",
        "shield_registry::ProtectionRegisteredEvent",
        "shield_registry::ProtectionDeregisteredEvent",
        "shield_vault::ReserveDepositedEvent",
        "shield_vault::ReserveWithdrawnEvent",
        "guardian_cap::GuardianCapMintedEvent",
        "guardian_cap::GuardianCapRevokedEvent"
      ]
    },
    {
      "key": "scallop",
      "role": "monitor-rescue-target",
      "packageEnv": "SCALLOP_PACKAGE_ID",
      "package": "0xd971609b7feb6230585831e7aeb3c121fb21b9431337a30fc99185eb459a05ee",
      "modules": ["borrow", "repay", "deposit_collateral", "liquidation"],
      "events": []
    },
    {
      "key": "scallop-mainnet",
      "role": "benchmark",
      "enabledEnv": "SCALLOP_MAINNET_BENCH",
      "graphqlUrl": "https://graphql.mainnet.sui.io/graphql",
      "package": "0xde5c09ad171544aa3724dc67216668c80e754860f419136a68d78504eb2e2805",
      "modules": ["borrow", "repay", "deposit_collateral", "withdraw_collateral", "liquidation"],
      "events": [],
      "note": "OPT-IN benchmark only (set SCALLOP_MAINNET_BENCH=1). Indexes real Scallop MAINNET lending events into SeFi to watch indexing speed in the FE. Off by default (full history is large)."
    },
    {
      "key": "navi",
      "role": "monitor-only",
      "packageEnv": "NAVI_PACKAGE_ID",
      "package": "",
      "modules": ["lending"],
      "events": []
    },
    {
      "key": "deepbook",
      "role": "liquidity-signal",
      "packageEnv": "DEEPBOOK_PACKAGE_ID",
      "package": "",
      "modules": [],
      "note": "Primary DeepBook liquidity signal comes from the DeepBook v3 indexer REST API (/summary, /orderbook), not on-chain events. On-chain event indexing optional."
    }
  ]
}
